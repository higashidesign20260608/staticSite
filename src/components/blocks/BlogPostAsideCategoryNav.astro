---
import type { ItfNavigation } from '../../types/type-navigation';
interface Props {
  subNavigations: ItfNavigation[];
};
const { subNavigations } = Astro.props;
---

<nav class="flex flex-wrap gap-2">
    {subNavigations.map((subNavigation:ItfNavigation) => (
      <a
        href={subNavigation.path}
        class="
          py-1
          px-3
          rounded-md
          border
          duration-300
          hover:-translate-y-1
        "
      >
        {subNavigation.label}
      </a>

    ))}
</nav>