---
interface Props {
	href: string;
	dispName: string;
	size: "s" | "m";
	active?: boolean;
}
const { href, dispName, size, active = true } = Astro.props
---

<a
	href={href}
	ontouchstart=""
	class=`
		${size === "s" ? "pl-4 pr-6 py-2" : "pl-6 pr-8 py-3"}
		rounded-full
		shadow-sm
		block
		
		${active ?
			"bg-acc-c text-base-c/80 duration-300 hover:-translate-y-1"
		:
			"pointer-events-none bg-white/90 text-gary-500"
		}
			relative
			after:content-['']
			after:absolute
			after:top-0
			after:bottom-0
			after:right-4
			after:w-2
			after:h-2
			after:m-auto
			after:border-t-3
			after:border-r-3
			after:rounded-xs
			after:border-base-c
			after:box-border
			after:rotate-45
	`
	>
	{dispName}
</a>