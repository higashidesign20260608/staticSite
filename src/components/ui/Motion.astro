<div id="motion" class="opacity-0 translate-y-10 duration-1000">
  <slot />
</div>

<script>
  const trgm = document.getElementById('motion');
  function motionS() {
    trgm!.classList.add('opacity-100');
    trgm!.classList.remove('translate-y-10');
  }

  window.onload = motionS;
</script>