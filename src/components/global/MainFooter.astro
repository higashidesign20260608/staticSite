---
import ShareSnsLinkIcon from "../ui/ShareSnsLinkIcon.astro";
interface Props {
  currentPageUrl: string;
  shareSnsText: string;
}
const { currentPageUrl, shareSnsText } = Astro.props;
---

<div
  class="
    grid-main
    py-10
  "
>
  <div
    class="
      col-span-4 md:col-span-8 lg:col-span-12
      flex flex-col
      justify-center items-center
    "
  >
    <p class="">share</p>
    <div
      class="
        flex
        justify-center
        items-center
        gap-4
        w-full
      "
    >
      <ShareSnsLinkIcon snsName={"x"} currentPageUrl={currentPageUrl} shareSnsText={shareSnsText} />
      <ShareSnsLinkIcon snsName={"line"} currentPageUrl={currentPageUrl} shareSnsText={shareSnsText} />
    </div>
  </div>
</div>