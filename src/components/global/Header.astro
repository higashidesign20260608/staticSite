---
import HeaderLogo from "../ui/Logo.astro"
import type { ItfNavigation } from "../../types/type-navigation";
import { baseUrl } from "../../constants/constant-common";
const siteUrl = import.meta.env.SITE;

interface Props {
	headerNavigations: ItfNavigation[];
	currentPageUrl: string;
};
const { headerNavigations, currentPageUrl } = Astro.props;
---

<header id="global-header"
	class="
		z-50
		fixed
		top-0
		right-0
		left-0
		duration-500
		md:translate-y-0
		text-sm
		lg:text-base
		shadow-sm
		backdrop-blur-md
	"
>
		<div class="container-global-header">
			<div class="grid-header items-center grid-rows-1 py-2">
				<div
					class="
						col-span-2
						lg:col-span-3
						flex
						justify-start
						items-center
					"
				>
					<HeaderLogo />
				</div>

				<nav
					id="nav-pc"
					class="
						hidden
						md:col-span-5
						md:col-end-9
						lg:col-span-6
						lg:col-end-13
						md:flex
						md:justify-end
						md:items-center
					"
				>
					<ul class="flex gap-4">
						{headerNavigations.map((headerNavigation:ItfNavigation)=>(
							<li>
								<a
									href={headerNavigation.path}
									ontouchstart=""
									class=`
										relative
										p-2
										${currentPageUrl === (siteUrl + baseUrl + headerNavigation.path) ? "after:opacity-100 after:bottom-0 pointer-events-none" : headerNavigation.path === "/" + baseUrl ? "" : currentPageUrl.includes(headerNavigation.path) ? "after:opacity-100 after:bottom-0 pointer-events-none":""}
									
									after:content-[''] after:absolute after:left-0 after:-bottom-4 after:w-full after:h-1 after:border-t-2 after:border-acc-c after:opacity-0 after:duration-300
									hover:after:opacity-100
									hover:after:bottom-0
									`
								>
									{headerNavigation.label}
								</a>
							</li>
						))}
					</ul>
				</nav>
				
				<nav
					id="nav-mobile"
					class="
						group/nav-mobile
						col-span-1
						col-end-5
						flex
						justify-end
						items-center
						h-full
					"
				>
					<button
						id="btn-humburger"
						type="button"
						aria-expanded="false"
						aria-controls="nav-list-mobile"
						class="
							flex
							justify-center
							items-center
							aspect-square
							h-full
							md:hidden
						"
					>
						<div
							class="
								flex
								flex-col 
								size-[40%]
								items-center
								group-has-aria-expanded/nav-mobile:justify-center
								not-group-has-aria-expanded/nav-mobile:justify-between
								"
							>
							<span
								class="
									block
									h-1
									w-full
									bg-acc-c
									rounded-full
									duration-300
									group-has-aria-expanded/nav-mobile:rotate-45
									group-has-aria-expanded/nav-mobile:translate-y-0.5
								"
							>
							</span>
							<span
								class="
									block
									h-1
									w-full
									bg-acc-c
									rounded-full
									duration-300
									group-has-aria-expanded/nav-mobile:hidden
								"
							>
							</span>
							<span
								class="
									block
									h-1
									w-full
									bg-acc-c
									rounded-full
									duration-300
									group-has-aria-expanded/nav-mobile:-rotate-45
									group-has-aria-expanded/nav-mobile:-translate-y-0.5
								"
							>
							</span>
						</div>
					</button>
					<div
						id="nav-list-mobile"
						class="
							-z-10
							fixed
							top-0
							-right-50
							left-full
							h-full
							opacity-0
							duration-400
							group-has-aria-expanded/nav-mobile:opacity-100
							group-has-aria-expanded/nav-mobile:right-0
							group-has-aria-expanded/nav-mobile:left-0
						"
					>
						<div
							class="
								grid-main
								pt-20
								h-lvh
								bg-base-c
							"
						>
							<ul 
								class="
									col-span-2
									col-start-2
								"
							>
								{headerNavigations.map((headerNavigation: ItfNavigation, index)=>(
									(headerNavigation.sub === null) ?
										<li
											class="
												border-b
												border-gray-200
												last:border-b-0
											"
										>
											<a
												href={headerNavigation.path}
												ontouchstart=""
												class="
													block
													size-full
													py-4
													active:bg-black/5
												"
											>
												{headerNavigation.label}
											</a>
										</li>
										:
										<li
											class="
												group/sub-nav-mobile
												border-b
												border-gray-200
												last:border-b-0
											"
										>
											<div class="flex justify-between items-center">
												<a
													href={headerNavigation.path}
													ontouchstart=""
													class="
														block
														size-full
														py-4
														active:bg-black/5
													"
												>
													{headerNavigation.label}
												</a>
												<button
													id={`btn-sub-nav-accordion-${index}`}
													type="button"
													aria-expanded="false"
													aria-controls={`sub-nav-list-${index}`}
													class="
														flex
														justify-center
														size-8
													"
												>
													<span
														class="
															block
															h-0.5
															w-2
															my-auto
															bg-gray-400
															translate-x-0.5
															rotate-45
															rounded-full
															transition-all
															duration-460
															group-has-aria-expanded/sub-nav-mobile:translate-x-1.5
															group-has-aria-expanded/sub-nav-mobile:rotate-235
															"
													></span>
													<span
														class="
															block
															h-0.5
															w-2
															my-auto
															bg-gray-400
															-translate-x-0.5
															-rotate-45
															rounded-full
															transition-all
															duration-460 
															group-has-aria-expanded/sub-nav-mobile:-translate-x-1.5
															group-has-aria-expanded/sub-nav-mobile:-rotate-235
															"
													></span>
												</button>
											</div>
											<ul
												id={`sub-nav-list-${index}`}
												class="
													max-h-0
													ml-4
													transition-all
													duration-500
													overflow-hidden
													group-has-aria-expanded/sub-nav-mobile:max-h-lvh
												"
											>
												{headerNavigation.sub.map((headerSubNavigation: ItfNavigation) => (
													<li class="mb-2">
														<a
															href={headerSubNavigation.path}
															ontouchstart=""
															class="
																block
																py-2
																active:bg-black/5
															"
														>
															{headerSubNavigation.label}
														</a>
													</li>
												))
												}
											</ul>
										</li>
									))
								}
							</ul>
						</div>
					</div>
				</nav>
				
			</div>
		</div>
</header>

<script>
	const btnAccordions = document.querySelectorAll('[id^="btn-sub-nav-accordion-"]');
	const btnHumburger = document.getElementById('btn-humburger');
	const globalHeader = document.getElementById('global-header');
	const bodyArea = document.body;

	// サブメニューのアコーディオン開閉ボタン
	btnAccordions.forEach(btnAccordion => {
		btnAccordion.addEventListener('click', () => {
			const isExpanded = btnAccordion.getAttribute('aria-expanded') === 'true';
			btnAccordion.setAttribute('aria-expanded', `${!isExpanded}`);
		});
	})

	// ハンバーガーメニュー開閉ボタン
	btnHumburger!.addEventListener('click', () => {
		const isExpanded = btnHumburger!.getAttribute('aria-expanded') === 'true';
		btnAccordions?.forEach(btnAccordion => {
			const isExpandedSub = btnAccordion.getAttribute('aria-expanded') === 'true';
			if (isExpandedSub) {
				btnAccordion.setAttribute('aria-expanded', `false`);
			}
		});
		btnHumburger!.setAttribute('aria-expanded', `${!isExpanded}`);
		if (!isExpanded) {
			if ((globalHeader!.classList.contains('-translate-y-[150%]'))) {
				globalHeader!.classList.remove('-translate-y-[150%]');
			}
			bodyArea.classList.add('overflow-hidden');
		} else {
			bodyArea.classList.remove('overflow-hidden');
		}
	});

	// 画面幅検知し、「サブメニューのアコーディオン開閉ボタン」「ハンバーガーメニュー開閉ボタン」をクローズ（false設定、active外す）する
	const mdSize = 768;
	const mediaQueryList = window.matchMedia(`(min-width: ${mdSize}px)`);

	mediaQueryList.addEventListener("change", (event) => {
		if (event.matches) {
			btnAccordions?.forEach(btnAccordion => {
				const isExpandedSub = btnAccordion.getAttribute('aria-expanded') === 'true';
				if (isExpandedSub) {
					btnAccordion.setAttribute('aria-expanded', `false`);
				}
			});
			btnHumburger!.setAttribute('aria-expanded', `false`);
			bodyArea.classList.remove('overflow-hidden');
		} else {
			btnAccordions?.forEach(btnAccordion => {
				const isExpandedSub = btnAccordion.getAttribute('aria-expanded') === 'true';
				if (isExpandedSub) {
					btnAccordion.setAttribute('aria-expanded', `false`);
				}
			});
			btnHumburger!.setAttribute('aria-expanded', `false`);
		}
	});

	// スクロール関連
	var startPos = 0, winScrollTop = 0;
	// scrollイベントを設定
	window.addEventListener('scroll', function () {
			winScrollTop = this.scrollY;
			if (winScrollTop >= startPos) {
					// 下にスクロールされた時
					if (winScrollTop >= 200) {
							// 下に200pxスクロールされたら隠す
							globalHeader!.classList.add('-translate-y-[150%]');
					}
			} else {
					// 上にスクロールされた時
					globalHeader!.classList.remove('-translate-y-[150%]');
			}
			startPos = winScrollTop;
	});
</script>