---
import BaseLayout from "../../layouts/BaseLayout.astro"
import MainLayout from "../../layouts/MainLayout.astro"
const url = Astro.url.href;

const pageTitle = "お問い合わせ"
const pageTitleEng = `CONTACT`
const pageDescription = "お問い合わせ"

// メールアドレス
// お名前
// entry.1443007973 mail
// entry.509032143　名前
// entry.722321010　本文
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription} ogpType="article" ogpUrl={url}>
	<MainLayout currentPageUrl={url} pageTitle={pageTitle} pageTitleEng={pageTitleEng} shareSnsText={pageDescription}>
		<div class="col-span-4 md:col-span-8 lg:col-span-12">
			<form
			id="google-form"
			action="https://docs.google.com/forms/u/0/d/e/1FAIpQLSfQJN1LbRt7fuVq3RlClRNyMu1AlsChn0v6ZQxeg1K2fBBwbA/formResponse"
			method="post"
			target="hidden-iframe"
			class="flex flex-col gap-8"
			onsubmit="submitted=true;"
			>
				<div class="flex flex-col gap-3">
					<div>
						<label for="name">お名前</label>
						<span class="bg-acc-c text-base-c rounded-md py-1 px-2 ml-4">必須</span>
					</div>
					<input type="text" id="name" name="entry.509032143" required class="border rounded-md py-2 px-4">
				</div>

				<div class="flex flex-col gap-3">
					<div>
						<label for="email">メールアドレス</label>
						<span class="bg-acc-c text-base-c rounded-md py-1 px-2 ml-4">必須</span>
					</div>
					<input type="email" id="email" name="entry.1443007973" required class="border rounded-md py-2 px-4">
				</div>

				<div class="flex flex-col gap-3">
					<div>
						<label for="message">お問い合わせ内容</label>
						<span class="bg-acc-c text-base-c rounded-md py-1 px-2 ml-4">必須</span>
					</div>
					<textarea id="message" name="entry.722321010" rows="5" class="border rounded-md py-2 px-4"></textarea>
				</div>

				<div style="display:none;">
						<label for="honeypot-field">このフィールドには入力しないでください</label>
						<input type="text" id="honeypot-field" name="honeypot-field">
				</div>

				<div class="mx-auto">
					<button id="submitButton" type="submit" class="py-3 px-6 rounded-full shadow-sm bg-acc-c text-base-c/80 duration-300 hover:-translate-y-1">送信する</button>
				</div>
		</form>
		<iframe name="hidden_iframe" id="hidden_iframe" style="display:none;"></iframe>
	</div>
	</MainLayout>
</BaseLayout>


<script>
	const customForm = document.getElementById('google-form');
	const submitButton = document.getElementById('submitButton') as HTMLButtonElement;
	
	customForm!.addEventListener("submit", (e) => {
		e.preventDefault();

		submitButton!.textContent="送信中...";
		submitButton!.disabled = true;

		const form = e.target as HTMLFormElement;
		const formData = new FormData(form);
		const honeypot = formData.get("honeypot-field");

		if (honeypot){
			console.log("botの可能性があるため送信不可")
			window.location.href = "/contact/thanks/";
			return;
		}

		fetch(form.action, {
			method: 'POST',
			body: formData,
			mode: 'no-cors'
		})

		.then(() => {
			window.location.href = "/contact/thanks/";
		})
	})
</script>