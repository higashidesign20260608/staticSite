---
import BaseLayout from "../../layouts/BaseLayout.astro"
import MainLayout from "../../layouts/MainLayout.astro"
const url = Astro.url.href;

const pageTitle = "ショップ"
const pageTitleEng = `SHOP`
const pageDescription = "shop"
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription} ogpType="article" ogpUrl={url}>
	<MainLayout currentPageUrl={url} pageTitle={pageTitle} pageTitleEng={pageTitleEng} shareSnsText={pageDescription}>
		<div class="col-span-4 md:col-span-8 lg:col-span-12 text-center">
			<p>以下サイトにて、作品を販売しております。</p>
		</div>
		<article class="col-span-2 md:col-span-4 lg:col-span-6 flex justify-center items-center h-20 md:h-30 lg:h-40">
			<a href="#">
				<img src="/shop-logo/minne-logo.png" alt="minneロゴ" class="w-30 md:w-40 lg:w-50 active:bg-black/10 hover:opacity-50">
			</a>
		</article>
		<article class="col-span-2 md:col-span-4 lg:col-span-6 flex justify-center items-center h-20 md:h-30 lg:h-40">
			<a href="#">
				<img src="/shop-logo/base-logo.png" alt="minneロゴ" class="w-30 md:w-40 lg:w-50 active:bg-black/10 hover:opacity-50">
			</a>
		</article>
	</MainLayout>
</BaseLayout>
